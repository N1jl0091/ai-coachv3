# ─────────────────────────────────────────────────────────────────────────────
# AI Coach Bot — Environment Variables
# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram after /newbot
TELEGRAM_BOT_TOKEN=

# Your own Telegram user id (only this id is allowed to use the bot).
# Get yours by messaging @userinfobot.
TELEGRAM_OWNER_ID=

# ── AI Providers (only populate the ones you actually use) ──────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Intervals.icu ───────────────────────────────────────────────────────────
# From Intervals.icu → Settings → Developer
INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=

# ── Strava ──────────────────────────────────────────────────────────────────
# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random string you choose — used to verify webhook subscription
STRAVA_VERIFY_TOKEN=ai-coach-verify-please-change-me

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=coach@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com

# ── Database ────────────────────────────────────────────────────────────────
# Railway injects this automatically when a Postgres service is attached.
# For local dev, point at a local Postgres (e.g. via docker run postgres).
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_coach

# ── GitHub Pages observability push ─────────────────────────────────────────
# Personal Access Token with `repo` scope so the scheduler can commit docs/.
GITHUB_TOKEN=
GITHUB_REPO=yourusername/ai-coach
# Branch GitHub Pages serves from. `main` is the default.
GITHUB_BRANCH=main

# ── Runtime ─────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. For local dev:
PORT=8000
LOG_LEVEL=INFO

# Athlete timezone (used when injecting "today is …" into prompts)
ATHLETE_TIMEZONE=Africa/Johannesburg
